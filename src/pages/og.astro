---
import PaintFlowShader from '../components/PaintFlowShader.astro';
---

<!doctype html>
<html lang="en" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1200" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=DM+Sans:opsz,wght@9..40,100..1000&display=swap" rel="stylesheet" />
    <title>OG Image</title>
    <style>
      @import "tailwindcss";

      @theme {
        --font-sans: "DM Sans", sans-serif;
        --font-display: "Anton", sans-serif;
        --color-brand-accent: hsl(25, 100%, 55%);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        width: 1200px;
        height: 630px;
        overflow: hidden;
        background: #0a0a0a;
      }

      .og-container {
        position: relative;
        width: 1200px;
        height: 630px;
        overflow: hidden;
      }

      .shader-bg {
        position: absolute;
        inset: 0;
        mask-image: radial-gradient(ellipse 90% 100% at 75% 40%, black 20%, transparent 65%);
        -webkit-mask-image: radial-gradient(ellipse 90% 100% at 75% 40%, black 20%, transparent 65%);
      }

      .shader-bg canvas {
        width: 100%;
        height: 100%;
      }

      .content {
        position: relative;
        z-index: 10;
        display: flex;
        align-items: center;
        height: 100%;
        padding: 0 80px;
        gap: 64px;
      }

      .text-side {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 24px;
      }

      .name-block {
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .profile-photo {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        object-fit: cover;
        outline: 2px solid rgba(255, 255, 255, 0.1);
        outline-offset: -2px;
      }

      .name-text h2 {
        font-family: "DM Sans", sans-serif;
        font-size: 24px;
        font-weight: 500;
        color: white;
        line-height: 1.2;
      }

      .name-text p {
        font-family: "DM Sans", sans-serif;
        font-size: 20px;
        color: rgb(115, 115, 115);
        line-height: 1.3;
      }

      .headline {
        font-family: "Anton", sans-serif;
        font-size: 72px;
        line-height: 1.1;
        text-transform: uppercase;
        color: white;
        max-width: 700px;
      }

      .url-btn {
        display: inline-flex;
        align-items: center;
        align-self: flex-start;
        font-family: "DM Sans", sans-serif;
        font-size: 24px;
        font-weight: 600;
        color: white;
        padding: 16px 36px;
        border-radius: 9999px;
        background-image: linear-gradient(to right in oklch, hsl(330, 100%, 50%), hsl(5, 90%, 50%));
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.25),
          inset 0 -1px 0 rgba(0, 0, 0, 0.15),
          0 10px 15px -3px hsl(25 100% 55% / 0.25),
          0 4px 6px -4px hsl(25 100% 55% / 0.25);
        letter-spacing: 0.02em;
      }

      .grain::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        opacity: 0.05;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      }
    </style>
  </head>
  <body>
    <div class="og-container grain">
      <div class="shader-bg">
        <PaintFlowShader class="size-full" />
      </div>
      <div class="content">
        <div class="text-side">
          <div class="name-block">
            <img src="/img/profile.jpg" alt="Sander Janssen" class="profile-photo" />
            <div class="name-text">
              <h2>Sander Janssen</h2>
              <p>Web Development</p>
            </div>
          </div>
          <h1 class="headline">High-quality websites for cultural & social organizations</h1>
          <span class="url-btn">sanderjanssen.nl</span>
        </div>
      </div>
    </div>
  </body>
</html>
