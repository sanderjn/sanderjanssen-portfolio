---
import { getImage } from 'astro:assets';
import '../styles/global.css';
import profileSrc from '../assets/img/profile.jpg';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Sander Janssen・Freelance Web Developer in Haarlem',
  description = 'Freelance front-end developer in Haarlem building high-quality websites for cultural and social organizations. Functional web design, Statamic CMS partner.',
} = Astro.props;

const siteUrl = Astro.site?.href ?? 'https://sanderjanssen.nl';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL('/img/og.jpg', siteUrl);
const profileImage = await getImage({ src: profileSrc, width: 400, format: 'webp' });
const profileImageUrl = new URL(profileImage.src, siteUrl).href;
---

<!doctype html>
<html lang="en" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Sander Janssen" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "name": "Sander Janssen",
          "url": "https://sanderjanssen.nl",
        },
        {
          "@type": "ProfessionalService",
          "name": "Sander Janssen",
          "url": "https://sanderjanssen.nl",
          "description": description,
          "image": profileImageUrl,
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Haarlem",
            "addressCountry": "NL",
          },
          "founder": {
            "@type": "Person",
            "name": "Sander Janssen",
            "jobTitle": "Freelance Web Developer",
            "url": "https://sanderjanssen.nl",
            "sameAs": [
              "https://github.com/sanderjn",
              "https://bsky.app/profile/sanderjanssen.nl",
            ],
          },
        },
      ],
    })} />
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var stickyHeader = document.querySelector('[data-sticky-header]');
        var heroHeader = document.querySelector('[data-hero-header]');

        if (prefersReducedMotion) {
          document.querySelectorAll('[data-animate], [data-animate-parent]').forEach(function (el) { el.classList.add('in-view'); });
          document.querySelectorAll('[data-testimonial]').forEach(function (el) {
            el.classList.add('is-visible');
            el.classList.add('is-sent');
          });
        } else {
          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                observer.unobserve(entry.target);
              }
            });
          }, { rootMargin: '0px 0px -15% 0px' });
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              document.querySelectorAll('[data-animate], [data-animate-parent]').forEach(function (el) { observer.observe(el); });
            });
          });

          var group = document.querySelector('[data-testimonial-group]');
          if (group) {
            var testimonialObserver = new IntersectionObserver(function (entries) {
              if (!entries[0].isIntersecting) return;
              testimonialObserver.disconnect();
              var items = group.querySelectorAll('[data-testimonial]');
              var offset = 0;
              items.forEach(function (el) {
                var chars = parseInt(el.dataset.chars) || 40;
                var typingDuration = Math.min(300 + chars * 3, 800);
                var showDelay = offset;
                var sendDelay = offset + typingDuration;

                setTimeout(function () { el.classList.add('is-visible'); }, showDelay);
                setTimeout(function () { el.classList.add('is-sent'); }, sendDelay);

                offset = sendDelay + 150;
              });
            }, { rootMargin: '0px 0px -10% 0px' });
            testimonialObserver.observe(group);
          }
        }

        if (stickyHeader && heroHeader) {
          new IntersectionObserver(function (entries) {
            stickyHeader.classList.toggle('is-visible', !entries[0].isIntersecting);
          }).observe(heroHeader);
        }
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
