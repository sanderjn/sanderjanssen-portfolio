---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<header data-sticky-header class:list={['sticky top-0 z-50 border-b border-white/0 bg-neutral-950/0 py-3 sm:py-4 backdrop-blur-none lg:hidden', className]}>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <nav class="flex items-center justify-between">
      <a href="/" class="group flex items-center gap-3" aria-label="Homepage">
        <img src="/img/profile.jpg" alt="Sander Janssen" class="size-9 rounded-full object-cover outline-1 -outline-offset-1 outline-white/10 transition-transform duration-200 ease-out-strong group-hover:scale-[1.03]" />
        <div>
          <p class="text-sm font-medium text-white">Sander Janssen</p>
          <p class="text-sm text-neutral-500">Web Development</p>
        </div>
      </a>
      <a href="mailto:hello@sanderjanssen.nl?Subject=Hello" class="rounded-full border border-white/8 px-4.5 py-2 text-base text-neutral-300 transition-[color,border-color,transform] duration-200 ease-out-strong hover:border-white/15 hover:text-white active:scale-[0.97] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-accent">Get in touch</a>
    </nav>
  </div>
</header>
