---
interface Props {
  number: string;
  muted?: boolean;
  color?: string;
  delay?: number;
  class?: string;
}

const { number, muted = false, color = 'text-brand-accent', delay, class: className } = Astro.props;
---

<li class:list={['flex gap-4', className]} {...(delay !== undefined ? { 'data-animate': '', style: `--stagger: ${delay}` } : {})}>
  <span class:list={['font-display text-3xl', muted ? 'text-neutral-700' : color]}>{number}</span>
  <span class:list={['pt-1 text-lg', muted ? 'text-neutral-600' : 'text-neutral-300']}>
    <slot />
  </span>
</li>
