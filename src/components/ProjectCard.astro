---
import ExternalLinkIcon from './ExternalLinkIcon.astro';

interface Props {
  href: string;
  image: string;
  tags: string;
  title: string;
  description: string;
  domain: string;
  reverse?: boolean;
  class?: string;
}

const { href, image, tags, title, description, domain, reverse = false, class: className } = Astro.props;
---

<a data-animate href={href} target="_blank" rel="noopener noreferrer" class:list={[
  'group grid items-center gap-6 lg:gap-16',
  reverse ? 'lg:grid-cols-[3fr_7fr]' : 'lg:grid-cols-[7fr_3fr]',
  className
]}>
  <div class:list={['aspect-[16/10] overflow-hidden rounded-xl bg-neutral-900', reverse && 'lg:order-2']}>
    <img src={image} alt="" class="size-full object-cover transition-transform duration-300 ease-out-strong group-hover:scale-105" />
  </div>
  <div class:list={[reverse && 'lg:order-1']}>
    <p class="text-base text-neutral-500">{tags}</p>
    <h3 class="mt-2 font-display text-2xl uppercase tracking-wide text-balance text-white">{title}</h3>
    <p class="mt-3 text-lg text-pretty text-neutral-400">{description}</p>
    <p class="mt-4 inline-block text-base font-medium text-brand-accent link-underline group-hover:text-brand-accent-light">{domain} <ExternalLinkIcon /></p>
  </div>
</a>
