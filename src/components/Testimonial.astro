---
interface Props {
  image: string;
  quote: string;
  author: string;
  company: string;
  align?: 'left' | 'right';
  class?: string;
}

const { image, quote, author, company, align = 'left', class: className } = Astro.props;
---

<div data-testimonial data-chars={quote.length} class:list={[
  'flex items-end gap-5',
  align === 'left' ? 'lg:max-w-[75%]' : 'lg:ml-auto lg:max-w-[75%] lg:flex-row-reverse',
  className
]}>
  <img src={image} alt="" class="testimonial-avatar size-12 shrink-0 rounded-full object-cover outline-1 -outline-offset-1 outline-brand-accent/20" />
  <div class="min-w-0">
    <blockquote class:list={['relative rounded-3xl bg-brand-accent/[0.07] ring-1 ring-brand-accent/10 px-8 py-6', align === 'left' ? 'rounded-bl-lg' : 'rounded-br-lg']}>
      <div class="typing-dots absolute inset-0 flex items-center gap-1.5 px-8">
        <span class="size-2 rounded-full bg-neutral-400/60"></span>
        <span class="size-2 rounded-full bg-neutral-400/60"></span>
        <span class="size-2 rounded-full bg-neutral-400/60"></span>
      </div>
      <p class="testimonial-text text-lg font-medium text-white text-pretty invisible">{quote}</p>
    </blockquote>
    <p class:list={['mt-2 text-base text-neutral-400', align === 'right' && 'lg:text-right']}>{author} &middot; <span class="text-brand-accent">{company}</span></p>
  </div>
</div>
